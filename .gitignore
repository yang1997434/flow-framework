.flow/config.local.yaml
.flow/workspace/*
!.flow/workspace/.gitkeep
.flow/**/*.tmp
.flow/**/.backup-*
.flow/tasks/**/.checkpoint/

# Claude Agent SDK local scratch (ephemeral worktrees, etc.)
.claude/
