# .flow/config.yaml — project-level config (committed to git)
# Generated by flow_init.py on {{DATE}}

version: 0.3.0

project:
  name: {{PROJECT_NAME}}
  type: backend  # backend | frontend | data | doc | deploy | research

# 任务类型 → 默认 skill 链（参考 docs/Skills-Phase映射.md）
default_skill_chain: backend

# Phase-specific overrides
phases:
  triage:
    model: haiku
  research:
    model: sonnet
    parallel_default: 2  # 默认并行 sub-agent 数
  implement:
    model: opus
    use_worktree_threshold_files: 3   # ≥3 files 用 worktree
    use_worktree_threshold_modules: 2  # 或 ≥2 模块
  check:
    model: sonnet
    upgrade_to_opus_layers: 3   # 跨 ≥3 层升 Opus
  verify:
    use_fresh_context: true     # generator/evaluator 模式
    model: sonnet
  codex_review:
    triggers:
      - critical
      - breaking
      - db_migration
      - api_contract_change
      - files_gte: 10
      - lines_gte: 500
    model: gpt-5.5

# Promotion 阈值
promotion:
  lv1_to_lv2:
    same_pattern_in_n_tasks: 2
    across_n_projects: 2
  lv2_to_lv3:
    used_n_times_no_exception: 3
  caps:
    adr_lines: 500
    pattern_lines: 300
    pitfall_body_chars: 800
    rule_lines: 200

# 凭据规约
credentials:
  ref_field: credentials_ref
  forbidden_in:
    - .flow/**/*.md
    - .trellis/**
  allowed_in:
    - ~/.flow/credentials.local
    - environment variables
  pre_commit_grep_patterns:
    - "(password|secret|api[_-]?key|token).*[:=]\\s*['\"][^'\"]+['\"]"

# Tool-count escape hatch（>10 工具退化单 agent，arxiv 2512.08296）
tool_count_escape_threshold: 10

# Team mode
team_mode: false  # true: workspace/<dev>/ committed, --assignee enforced
