# .flow/config.yaml — project-level config (committed to git)
# Generated by flow_init.py on {{DATE}}

version: 0.3.0

project:
  name: {{PROJECT_NAME}}
  type: backend  # backend | frontend | data | doc | deploy | research

# 任务类型 → 默认 skill 链（参考 docs/Skills-Phase映射.md）
default_skill_chain: backend

# Phase-specific overrides
phases:
  triage:
    model: haiku
  research:
    model: sonnet
    parallel_default: 2  # 默认并行 sub-agent 数
  implement:
    model: opus
    use_worktree_threshold_files: 3   # ≥3 files 用 worktree
    use_worktree_threshold_modules: 2  # 或 ≥2 模块
  check:
    model: sonnet
    upgrade_to_opus_layers: 3   # 跨 ≥3 层升 Opus
  verify:
    use_fresh_context: true     # generator/evaluator 模式
    model: sonnet
  codex_review:
    triggers:
      - critical
      - breaking
      - db_migration
      - api_contract_change
      - files_gte: 10
      - lines_gte: 500
    model: gpt-5.5

# Promotion 阈值
promotion:
  lv1_to_lv2:
    same_pattern_in_n_tasks: 2
    across_n_projects: 2
  lv2_to_lv3:
    used_n_times_no_exception: 3
  caps:
    adr_lines: 500
    pattern_lines: 300
    pitfall_body_chars: 800
    rule_lines: 200

# 凭据规约
credentials:
  ref_field: credentials_ref
  forbidden_in:
    - .flow/**/*.md
    - .trellis/**
  allowed_in:
    - ~/.flow/credentials.local
    - environment variables
  pre_commit_grep_patterns:
    - "(password|secret|api[_-]?key|token).*[:=]\\s*['\"][^'\"]+['\"]"

# Tool-count escape hatch（>10 工具退化单 agent，arxiv 2512.08296）
tool_count_escape_threshold: 10

# Team mode
team_mode: false  # true: workspace/<dev>/ committed, --assignee enforced

# Task isolation strategy (v0.4 — multi-task parallel)
#   worktree — each task gets its own git worktree at ../<repo>-flow-<slug>
#              (recommended for git repos; falls back to shared if not a git repo)
#   branch   — switch branches in-place (single tree, may conflict)
#   shared   — single shared working tree, switch via .current-task pointer (v0.3 default)
# Default is `shared` because non-git repos must safely fall back; opt in to `worktree`
# only when project is a git repo and you want true isolation.
task_isolation: shared  # worktree | branch | shared

# Phase 2 execution mode (v0.4)
#   interactive          — main session orchestrates sub-agents (default, human-in-the-loop)
#   ralph-loop           — bash loop calling `claude --print` headlessly until PRD's
#                          Acceptance Criteria checklist is complete or --max-iterations
#                          is reached. See scripts/flow_ralph.sh. Best for long autonomous
#                          runs against PRDs whose criteria are individually testable.
#   parallel-subagents   — N parallel sub-agents in worktrees (current main flow for
#                          ≥3 independent modules).
phase2_mode: interactive

# Layer-2 semantic checkpoint (v0.4 — Lv1/Lv2/Lv3 event-driven save).
# Layer-1 raw persistence is delegated to context-mode plugin.
autosave:
  heartbeat_minutes: 30           # Lv3 heartbeat: time threshold
  heartbeat_tool_calls: 50        # Lv3 heartbeat: tool-call threshold
  distill_cooldown_minutes: 5     # min gap between non-explicit Lv3 distills
